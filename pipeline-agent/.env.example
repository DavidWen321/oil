# ==========================================
# Pipeline Agent - Environment Variables
# ==========================================

# ===== LLM Configuration =====
# 通义千问 (推荐)
OPENAI_API_KEY=__REQUIRED__
OPENAI_API_BASE=https://api.penguinsaichat.dpdns.org/v1
LLM_MODEL=claude-opus-4-6
LLM_LIGHT_MODEL=claude-haiku-3-5
LLM_MEDIUM_MODEL=claude-sonnet-4
LLM_HEAVY_MODEL=claude-opus-4-6
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=__REQUIRED__

# 或使用OpenAI
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_BASE=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small

# ===== Database Configuration =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=__REQUIRED__
DB_NAME=pipeline_cloud

# ===== Redis Configuration =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== Workflow Persistence =====
CHECKPOINT_BACKEND=redis
CHECKPOINT_REDIS_URL=redis://localhost:6379/1
CHECKPOINT_PENDING_TTL_SECONDS=1800

# ===== Milvus Configuration =====
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=pipeline_knowledge

# ===== Java Service Configuration =====
JAVA_GATEWAY_URL=http://localhost:8080
JAVA_ALLOWED_HOSTS=localhost,127.0.0.1,::1
JAVA_AUTH_USERNAME=admin
JAVA_AUTH_PASSWORD=__REQUIRED__

# ===== Agent Configuration =====
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=60
TOOL_MAX_CALLS_PER_SESSION=20
TOOL_MAX_CALLS_PER_TOOL=10

# ===== RAG Configuration =====
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=10
RAG_FINAL_K=5
RAG_USE_HYPE=true
RAG_USE_RERANKING=true
RAG_USE_CONTEXTUAL=true
RAG_USE_SELF_RAG=true
RAG_USE_QUERY_REWRITE=true


# ===== SQL Safety =====
SQL_QUERY_TIMEOUT_SECONDS=30
SQL_CONNECT_TIMEOUT_SECONDS=10
SQL_MAX_LIMIT=100
SQL_ALLOWED_TABLES=t_project,t_pipeline,t_pump_station,t_oil_property,t_calculation_history,t_calculation_result,t_sensitivity_analysis,t_kg_node,t_kg_edge,t_agent_trace,t_agent_trace_event,t_hitl_record,t_analysis_report
SQL_BLOCKED_TABLES=sys_user,sys_role,sys_menu,sys_config,sys_dict_data,sys_dict_type,sys_logininfor,sys_oper_log

# ===== Auth / Gateway =====
AUTH_REQUIRED_IN_PRODUCTION=true
INTERNAL_SERVICE_TOKEN=__REQUIRED_IN_PROD__
INTERNAL_API_KEY=
ALLOWED_BEARER_TOKENS=
TRUSTED_GATEWAY_IPS=127.0.0.1,::1

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8100
DEBUG=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/agent.log
